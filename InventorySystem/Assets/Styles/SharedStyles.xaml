<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="LoadingOverlay" TargetType="Grid">
        <Setter Property="Background" Value="#80000000"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LoadingSpinner" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Canvas Width="40" Height="40">
                        <Ellipse Width="40" Height="40" Stroke="{StaticResource Primary Color}" StrokeThickness="4" StrokeDashArray="3 1">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="Rotate" CenterX="20" CenterY="20" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Rotate" 
                                                             Storyboard.TargetProperty="Angle" 
                                                             From="0" To="360" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Canvas>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Action Buttons -->
    <Style x:Key="PremiumActionBtn" TargetType="Button">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="btnEdit" TargetType="Button" BasedOn="{StaticResource PremiumActionBtn}">
        <Setter Property="Background" Value="{StaticResource SoftEditBg}"/>
        <Setter Property="Foreground" Value="{StaticResource SoftEditFg}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SoftEditHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="btnDelete" TargetType="Button" BasedOn="{StaticResource PremiumActionBtn}">
        <Setter Property="Background" Value="{StaticResource SoftDeleteBg}"/>
        <Setter Property="Foreground" Value="{StaticResource SoftDeleteFg}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SoftDeleteHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="btnInfo" TargetType="Button" BasedOn="{StaticResource PremiumActionBtn}">
        <Setter Property="Background" Value="{StaticResource SoftInfoBg}"/>
        <Setter Property="Foreground" Value="{StaticResource SoftInfoFg}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SoftInfoHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
