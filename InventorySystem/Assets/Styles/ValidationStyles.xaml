<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palette for Validation -->
    <Color x:Key="ErrorColor">#EF4444</Color>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

    <!-- Error Template -->
    <ControlTemplate x:Key="ValidationErrorTemplate">
        <StackPanel>
            <AdornedElementPlaceholder x:Name="placeholder"/>
            <Border Background="{StaticResource ErrorBrush}" CornerRadius="0,0,5,5" Margin="0,-2,0,0">
                <TextBlock Text="{Binding [0].ErrorContent}" 
                           Foreground="White" 
                           FontSize="10" 
                           Padding="5,2"
                           FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </ControlTemplate>

    <!-- Base TextBox Style with Validation -->
    <Style x:Key="ValidatingTextBox" TargetType="TextBox">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="true">
                <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
