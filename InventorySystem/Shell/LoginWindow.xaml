<Window x:Class="InventorySystem.Shell.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="InventorySystem — Login"
        Width="900" Height="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Input field style -->
        <Style x:Key="LoginInput" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="LoginPasswordInput" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Login button -->
        <Style x:Key="LoginBtn" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#818CF8" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Shadow border -->
    <Border CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left panel: branding -->
                <ColumnDefinition Width="400"/>
                <!-- Right panel: form -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Brand panel -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E1B4B" Offset="0"/>
                        <GradientStop Color="#3730A3" Offset="0.5"/>
                        <GradientStop Color="#4F46E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Decorative circles -->
                    <Ellipse Width="300" Height="300" HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-100,-80,0,0" Opacity="0.08">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="White"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="200" Height="200" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-60,-60" Opacity="0.06">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="White"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Logo icon -->
                        <Border Width="80" Height="80" CornerRadius="24" HorizontalAlignment="Center"
                                Margin="0,0,0,24">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
                            </Border.Background>
                            <fa:IconImage Icon="BoxesStacked" Foreground="White" Width="40" Height="40"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="INVST" Foreground="White" FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource LoginBrandSubtext}" Foreground="#A5B4FC" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,4,0,32"/>

                        <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.15" Margin="0,0,0,28"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <fa:IconImage Icon="ShieldAlt" Foreground="#6EE7B7" Width="16" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource LoginFeatureSecure}" Foreground="#A5B4FC" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <fa:IconImage Icon="ChartLine" Foreground="#6EE7B7" Width="16" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource LoginFeatureAnalytics}" Foreground="#A5B4FC" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:IconImage Icon="FileInvoiceDollar" Foreground="#6EE7B7" Width="16" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource LoginFeaturePOS}" Foreground="#A5B4FC" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT: Login form -->
            <Border Grid.Column="1" CornerRadius="0,16,16,0" Background="#0F172A">
                <!-- Close button -->
                <Grid>
                    <Button x:Name="BtnClose" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,14,14,0" Width="28" Height="28"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="BtnClose_Click">
                        <fa:IconImage Icon="Xmark" Foreground="#475569" Width="14"/>
                    </Button>

                    <StackPanel VerticalAlignment="Center" Margin="50,0,50,0">
                        <TextBlock Text="{DynamicResource LoginWelcomeBack}" Foreground="White" FontSize="26" FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{DynamicResource LoginSignInSubtitle}" Foreground="#64748B"
                                   FontSize="13" Margin="0,0,0,40"/>

                        <!-- Username field -->
                        <TextBlock Text="{DynamicResource LoginLabelUsername}" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border Background="#1E293B" CornerRadius="10" Height="48" Margin="0,0,0,20"
                                x:Name="UsernameBorder">
                            <Grid>
                                <fa:IconImage Icon="User" Foreground="#475569" Width="14"
                                              HorizontalAlignment="Left" Margin="16,0,0,0"/>
                                <TextBox x:Name="TxtUsername"
                                         Style="{StaticResource LoginInput}"
                                         Margin="44,0,16,0"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="Input_KeyDown"/>
                            </Grid>
                        </Border>

                        <!-- Password field -->
                        <TextBlock Text="{DynamicResource LoginLabelPassword}" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border Background="#1E293B" CornerRadius="10" Height="48" Margin="0,0,0,8"
                                x:Name="PasswordBorder">
                            <Grid>
                                <fa:IconImage Icon="Lock" Foreground="#475569" Width="14"
                                              HorizontalAlignment="Left" Margin="16,0,0,0"/>
                                <PasswordBox x:Name="PwdPassword"
                                             Style="{StaticResource LoginPasswordInput}"
                                             Margin="44,0,16,0"
                                             KeyDown="Input_KeyDown"
                                             PasswordChanged="PwdPassword_PasswordChanged"/>
                            </Grid>
                        </Border>

                        <!-- Error message -->
                        <Border Background="#450A0A" CornerRadius="8" Padding="12,8" Margin="0,0,0,8"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="CircleExclamation" Foreground="#F87171" Width="14" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Loading indicator -->
                        <Border Margin="0,0,0,4" Height="4" CornerRadius="2"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#818CF8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Login button -->
                        <Button x:Name="BtnLogin"
                                Style="{StaticResource LoginBtn}"
                                Height="48"
                                Content="{DynamicResource LoginButtonText}"
                                Command="{Binding LoginCommand}"
                                Margin="0,16,0,0"/>

                        <!-- Version tag -->
                        <TextBlock Text="{DynamicResource LoginVersionTag}" Foreground="#1E293B"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,28,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
