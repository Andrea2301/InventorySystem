<Window x:Class="InventorySystem.Views.ImportFileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.Views"
        xmlns:viewModel="clr-namespace:InventorySystem.ViewModel"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="Import File" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style TargetType="StackPanel" x:Key="SelectedFilePanel">
             <Style.Triggers>
                 <DataTrigger Binding="{Binding SelectedFilePath}" Value="">
                     <Setter Property="Visibility" Value="Collapsed"/>
                 </DataTrigger>
                  <DataTrigger Binding="{Binding SelectedFilePath}" Value="{x:Null}">
                     <Setter Property="Visibility" Value="Collapsed"/>
                 </DataTrigger>
             </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Gray"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Drop Zone -->
                <RowDefinition Height="60"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="#3F51B5">
                <Grid>
                    <TextBlock Text="Import Excel File" 
                               Foreground="White" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>

                    <Button HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,10,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <fa:IconImage Icon="Times" Foreground="White" Width="15" Height="15"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Drop Zone -->
            <Grid Grid.Row="1" Margin="20">
                
                <!-- Dashed Border Background -->
                <Rectangle RadiusX="10" RadiusY="10" 
                           StrokeThickness="2" 
                           SnapsToDevicePixels="True"
                           RenderOptions.EdgeMode="Aliased">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Setter Property="Stroke" Value="#9FA8DA"/>
                            <Setter Property="Fill" Value="#F8F9FA"/>
                            <Setter Property="StrokeDashArray" Value="4 2"/>
                            
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                    <Setter Property="Fill" Value="#E8EAF6"/>
                                    <Setter Property="Stroke" Value="#3F51B5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>

                <!-- Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <fa:IconImage Icon="CloudUploadAlt" 
                                  Foreground="#3F51B5" 
                                  Width="60" 
                                  Height="60" 
                                  Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Drag &amp; Drop your Excel file here" 
                               Foreground="#37474F" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Supported formats: .xlsx, .xls" 
                                   Foreground="#90A4AE" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                    <Button Content="Browse Files" 
                            Padding="15,8"
                            Background="White"
                            Foreground="#3F51B5"
                            BorderBrush="#3F51B5"
                            BorderThickness="1"
                            Command="{Binding BrowseFileCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                    <!-- Selected File Display -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="0,20,0,0"
                                Style="{StaticResource SelectedFilePanel}">
                        
                        <fa:IconImage Icon="FileExcel" Foreground="#2E7D32" Width="16" Height="16" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding SelectedFilePath}" 
                                   Foreground="#2E7D32" 
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="300"/>
                    </StackPanel>

                </StackPanel>
                
                <!-- Overlay for Drag Events (Hack if we want to handle events on the Grid) -->
                <Grid Background="Transparent" 
                      AllowDrop="True"
                      Drop="Grid_Drop"
                      DragEnter="Grid_DragEnter"
                      DragLeave="Grid_DragLeave"/>
                
            </Grid>

            <!-- Footer Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                <Button Content="Cancel" 
                        Width="100" Height="35" 
                        Margin="0,0,10,0"
                        Background="White"
                        Foreground="#3F51B5"
                        BorderBrush="#3F51B5"
                        BorderThickness="1"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Import" 
                        Width="100" Height="35"
                        Background="#3F51B5"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding ConfirmImportCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

        </Grid>
    </Border>

</Window>
