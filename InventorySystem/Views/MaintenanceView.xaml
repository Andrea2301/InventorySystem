<UserControl x:Class="InventorySystem.Views.MaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:InventorySystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    
    <Grid Background="#F3F4F6">
        <Border Background="White" Margin="30" CornerRadius="20" MaxWidth="800" VerticalAlignment="Top">
            <StackPanel Margin="40">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <fa:IconImage Icon="Database" Foreground="#4F46E5" Width="32" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="Database &amp; Maintenance" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Protect your information and manage backups." Foreground="#6B7280" FontSize="14"/>
                    </StackPanel>
                </StackPanel>

                <!-- Info Section -->
                <Border Background="#F9FAFB" CornerRadius="12" Padding="20" Margin="0,0,0,30" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Current location:" FontWeight="SemiBold" Foreground="#374151" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding DatabasePath}" Foreground="#6B7280" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" TextWrapping="Wrap"/>

                        <TextBlock Text="Data size:" FontWeight="SemiBold" Foreground="#374151" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock Text="{Binding DatabaseSize}" Foreground="#6B7280" Grid.Row="2" Grid.Column="1" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Actions Section -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Backup Card -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="15" Padding="25">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="60" Height="60" CornerRadius="30" Background="#EEF2FF" Margin="0,0,0,15">
                                <fa:IconImage Icon="CloudDownloadAlt" Foreground="#4F46E5" Width="26"/>
                            </Border>
                            <TextBlock Text="Backup" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Create a backup of all your data in a secure location." 
                                       TextAlignment="Center" Foreground="#6B7280" Margin="0,0,0,20" TextWrapping="Wrap"/>
                            
                            <Button Content="Create Backup" 
                                    Style="{StaticResource Pop}"
                                    Command="{Binding BackupCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"
                                    Height="40" Padding="20,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Restore Card -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="15" Padding="25">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="60" Height="60" CornerRadius="30" Background="#FEF2F2" Margin="0,0,0,15">
                                <fa:IconImage Icon="History" Foreground="#DC2626" Width="26"/>
                            </Border>
                            <TextBlock Text="Restore Data" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Recover information from a previously saved copy." 
                                       TextAlignment="Center" Foreground="#6B7280" Margin="0,0,0,20" TextWrapping="Wrap"/>

                            <Button Content="Restore Copy" 
                                    Style="{StaticResource btnDelete}"
                                    Command="{Binding RestoreCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}"
                                    Height="40" Padding="20,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Busy Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0" 
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Control Style="{StaticResource LoadingSpinner}" Width="20" Height="20" Margin="0,0,10,0"/>
                    <TextBlock Text="Processing files..." Foreground="#4F46E5" FontWeight="SemiBold"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
