<UserControl x:Class="InventorySystem.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:InventorySystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="#F3F4F6">

        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock Text="Products" 
                       Grid.Column="0"
                       FontSize="28" 
                       FontWeight="SemiBold" 
                       Foreground="#1F2937" 
                       VerticalAlignment="Center"/>

            <!-- Right Actions Group -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Search Bar -->
                <Border CornerRadius="20" 
                        Background="White" 
                        Width="250" 
                        Height="40" 
                        Margin="0,0,15,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#E5E7EB" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search Icon -->
                        <fa:IconImage Icon="Search" 
                                      Foreground="#9CA3AF"
                                      Width="16"
                                      Height="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        
                        <!-- Input with Placeholder -->
                        <Grid Grid.Column="1">
                            <TextBlock Text="Search products..."
                                       Foreground="#9CA3AF"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Padding="2,0,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                                    <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <TextBox x:Name="SearchBox"
                                     Foreground="#4B5563"
                                     FontSize="14"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Padding="0,0,10,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Filter Button -->
                <Button Background="White"
                        BorderThickness="0"
                        Width="40"
                        Height="40"
                        Margin="0,0,15,0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#E5E7EB" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                                </Border.Effect>
                                <fa:IconImage Icon="Filter" Foreground="#475dbd" Width="16" Height="16"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Add Product Button -->
                <Grid>
                    <ToggleButton x:Name="AddProductBtn"
                                  Width="40"
                                  Height="40"
                                  Cursor="Hand"
                                  BorderThickness="0"
                                  Style="{StaticResource AddButton}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border CornerRadius="20" Background="#4F46E5">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#C7D2FE" BlurRadius="10" ShadowDepth="4" Opacity="0.8"/>
                                    </Border.Effect>
                                    <fa:IconImage Icon="Plus" Foreground="White" Width="16" Height="16"/>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <Popup PlacementTarget="{Binding ElementName=AddProductBtn}"
                           Placement="Bottom"
                           HorizontalOffset="-100"
                           IsOpen="{Binding IsChecked, ElementName=AddProductBtn}"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="5"
                                Margin="0,5,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#E5E7EB" Opacity="0.5" ShadowDepth="5"/>
                            </Border.Effect>
                            <StackPanel Margin="5">
                                <Button Content="New Product"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding OpenProductFormCommand}"/>
                                <Button Content="Import from Excel"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding OpenImportExcelCommand}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

            </StackPanel>
        </Grid>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1" 
                      Margin="10,0,10,10" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- CARD -->
                        <Border Background="White" 
                                CornerRadius="15" 
                                Width="200" 
                                Height="280" 
                                Margin="10">
                            
                            <Border.Effect>
                                <DropShadowEffect Color="#E5E7EB" BlurRadius="15" ShadowDepth="4" Opacity="0.6"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/> <!-- Image -->
                                    <RowDefinition Height="*"/>   <!-- Info -->
                                    <RowDefinition Height="40"/>  <!-- Actions -->
                                </Grid.RowDefinitions>

                                <!-- 1. IMAGE SECTION -->
                                <Border Grid.Row="0" CornerRadius="15,15,0,0" Background="#F9FAFB" ClipToBounds="True">
                                    <Grid>
                                        <!-- Placeholder Icon (shows if image is null) -->
                                        <fa:IconImage Icon="BoxOpen" 
                                                      Foreground="#E5E7EB" 
                                                      Width="40" 
                                                      Height="40"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        
                                        <!-- Actual Image -->
                                        <Image Source="{Binding ImageData}" 
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                        
                                        <!-- Status Badge (Overlay) -->
                                        <Border VerticalAlignment="Top" 
                                                HorizontalAlignment="Right" 
                                                Margin="10" 
                                                CornerRadius="8" 
                                                Padding="8,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F3F4F6"/> <!-- Default -->
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="In Stock">
                                                            <Setter Property="Background" Value="#E8F5E9"/> <!-- Green Light -->
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Out of Stock">
                                                            <Setter Property="Background" Value="#FFEBEE"/> <!-- Red Light -->
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="In Stock">
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Out of Stock">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 2. INFO SECTION -->
                                <StackPanel Grid.Row="1" Margin="12,8,12,5">
                                    
                                    <!-- Category -->
                                    <TextBlock Text="{Binding Category}" 
                                               Foreground="#9CA3AF" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Name -->
                                    <TextBlock Text="{Binding Name}" 
                                               Foreground="#1F2937" 
                                               FontSize="14" 
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,3"/>

                                    <!-- Qty -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <fa:IconImage Icon="LayerGroup" Width="10" Height="10" Foreground="#9CA3AF" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Quantity, StringFormat='{}Stock: {0}'}" 
                                                   Foreground="#6B7280" 
                                                   FontSize="11"/>
                                    </StackPanel>

                                    <!-- Price -->
                                    <TextBlock Text="{Binding Price, StringFormat=C}" 
                                               Foreground="#4F46E5" 
                                               FontSize="16" 
                                               FontWeight="ExtraBold"
                                               VerticalAlignment="Bottom"/>
                                </StackPanel>

                                <!-- 3. ACTIONS SECTION -->
                                <Border Grid.Row="2" 
                                        BorderBrush="#F3F4F6" 
                                        BorderThickness="0,1,0,0"
                                        Padding="15,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            
                                            <Button Style="{StaticResource Edit}" 
                                                    Width="32" Height="32" 
                                                    Margin="0,0,8,0"
                                                    Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <fa:IconImage Icon="Edit" Width="12" Height="12"/>
                                            </Button>

                                            <Button Style="{StaticResource Delete}" 
                                                    Width="32" Height="32"
                                                    Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <fa:IconImage Icon="Trash" Width="12" Height="12"/>
                                            </Button>

                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
