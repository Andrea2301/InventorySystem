<Window x:Class="InventorySystem.Views.ProductFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:local="clr-namespace:InventorySystem.Views"
        mc:Ignorable="d" 
        Title="{Binding FormTitle}" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid Background="White">
        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Margin="10" Background="White">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Title -->
                    <RowDefinition Height="Auto"/> <!-- Image -->
                    <RowDefinition Height="*"/>    <!-- Form -->
                    <RowDefinition Height="Auto"/> <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Text="{Binding FormTitle}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#333" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>

                <!-- Image Selection -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="120" Height="120" CornerRadius="60" BorderBrush="#E0E0E0" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <!-- Placeholder -->
                            <fa:IconImage Icon="BoxOpen" Foreground="#CCC" Width="50" Height="50" 
                                          Visibility="{Binding PreviewImage, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Visible}"/>
                            
                            <!-- Preview Image -->
                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                        </Grid>
                    </Border>
                    <Button Content="Select Image" 
                            Command="{Binding SelectImageCommand}"
                            Margin="0,10,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Foreground="#3f51b5"/>
                </StackPanel>

                <!-- Form Fields -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Name" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Product.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Category" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Product.Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Price" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Product.Price, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Quantity" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Product.Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Description" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Product.Description, UpdateSourceTrigger=PropertyChanged}" 
                             Height="80" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" 
                             AcceptsReturn="True"
                             Margin="0,0,0,15" Padding="5"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Cancel" 
                            Command="{Binding CancelCommand}"
                            Background="Transparent" 
                            BorderBrush="#CCC" 
                            BorderThickness="1"
                            Foreground="#666"
                            Margin="0,0,10,0"
                            Width="100"/>
                    
                    <Button Content="Save Product" 
                            Command="{Binding SaveCommand}"
                            Background="#3f51b5" 
                            BorderThickness="0"
                            Foreground="White"
                            Width="120"/>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
