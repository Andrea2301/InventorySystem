<Window x:Class="InventorySystem.Views.ClientFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InventorySystem.Views"
        xmlns:viewModel="clr-namespace:InventorySystem.ViewModel"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="Client Form" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="10" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Gray"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Form -->
                <RowDefinition Height="60"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="#3F51B5">
                <Grid>
                    <TextBlock Text="New Client" 
                               Foreground="White" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>

                    <Button HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,10,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <fa:IconImage Icon="Times" Foreground="White" Width="15" Height="15"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Form Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
                <StackPanel>
                    
                    <!-- ID / Document Number -->
                    <TextBlock Text="Document Number" Foreground="#757575" Margin="0,10,0,5"/>
                    <TextBox Text="{Binding Client.DocumentNumber}" Style="{StaticResource textBox}" Padding="5" Height="30"/>

                    <!-- Names -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" Foreground="#757575" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Client.FirstName}" Style="{StaticResource textBox}" Padding="5" Height="30"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" Foreground="#757575" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Client.LastName}" Style="{StaticResource textBox}" Padding="5" Height="30"/>
                        </StackPanel>
                    </Grid>

                    <!-- Contact -->
                    <TextBlock Text="Email" Foreground="#757575" Margin="0,10,0,5"/>
                    <TextBox Text="{Binding Client.Email}" Style="{StaticResource textBox}" Padding="5" Height="30"/>

                    <TextBlock Text="Phone" Foreground="#757575" Margin="0,10,0,5"/>
                    <TextBox Text="{Binding Client.PhoneNumber}" Style="{StaticResource textBox}" Padding="5" Height="30"/>

                    <!-- Address -->
                    <TextBlock Text="Address" Foreground="#757575" Margin="0,10,0,5"/>
                    <TextBox Text="{Binding Client.Address}" Style="{StaticResource textBox}" Padding="5" Height="60" TextWrapping="Wrap"/>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                <Button Content="Cancel" 
                        Width="100" Height="35" 
                        Margin="0,0,10,0"
                        Background="White"
                        Foreground="#3F51B5"
                        BorderBrush="#3F51B5"
                        BorderThickness="1"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Save" 
                        Width="100" Height="35"
                        Background="#3F51B5"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>
