<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mahApps="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    x:Class="InventorySystem.Views.InformsView"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="20,15">
            <TextBlock Text="Reports &amp; Analytics" 
                       FontSize="28" 
                       FontWeight="SemiBold" 
                       Foreground="#1F2937" 
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel Margin="20" HorizontalAlignment="Center">
                
                <!-- Sales Report Card -->
                <Border Width="300" Height="200" Background="White" CornerRadius="15" Margin="10" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#E5E7EB" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Border Background="#EEF2FF" CornerRadius="8" Padding="10">
                                <fa:IconImage Icon="ChartLine" Foreground="#4F46E5" Width="24" Height="24"/>
                            </Border>
                            <TextBlock Text="Sales Report" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#1F2937"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Comprehensive analysis of sales performance, top products, and revenue trends." 
                                   TextWrapping="Wrap" Foreground="#6B7280" Margin="0,15,0,0" FontSize="14"/>

                        <Button Grid.Row="2" 
                                Content="Generate PDF" 
                                Background="#4F46E5" 
                                Foreground="White"
                                Height="40"
                                Cursor="Hand"
                                Command="{Binding GenerateSalesReportCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Clients Report Card (Coming Soon) -->
                <Border Width="300" Height="200" Background="White" CornerRadius="15" Margin="10" Opacity="0.7" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#E5E7EB" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Border Background="#F0FDF4" CornerRadius="8" Padding="10">
                                <fa:IconImage Icon="Users" Foreground="#16A34A" Width="24" Height="24"/>
                            </Border>
                            <TextBlock Text="Clients Report" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#1F2937"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Detailed breakdown of client behavior and loyalty metrics." 
                                   TextWrapping="Wrap" Foreground="#6B7280" Margin="0,15,0,0" FontSize="14"/>

                        <Button Grid.Row="2" Content="Soon" IsEnabled="False" Height="40"/>
                    </Grid>
                </Border>

                <!-- Suppliers Report Card (Coming Soon) -->
                <Border Width="300" Height="200" Background="White" CornerRadius="15" Margin="10" Opacity="0.7" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#E5E7EB" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <Border Background="#FFF7ED" CornerRadius="8" Padding="10">
                                <fa:IconImage Icon="Truck" Foreground="#EA580C" Width="24" Height="24"/>
                            </Border>
                            <TextBlock Text="Suppliers Report" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#1F2937"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Inventory costs and supplier performance evaluation." 
                                   TextWrapping="Wrap" Foreground="#6B7280" Margin="0,15,0,0" FontSize="14"/>

                        <Button Grid.Row="2" Content="Soon" IsEnabled="False" Height="40"/>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
