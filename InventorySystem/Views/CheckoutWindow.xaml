<Window x:Class="InventorySystem.Views.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:helpers="clr-namespace:InventorySystem.Helpers"
        mc:Ignorable="d"
        Title="Finalizar Transacción" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Style to toggle Visibility based on PaymentMethod -->
        <Style x:Key="CashPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding PaymentMethod}" Value="Efectivo">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DigitalPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding PaymentMethod}" Value="Pago Digital">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Payment Method Selection Buttons -->
        <Style x:Key="PaymentMethodRadioStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="White" 
                                BorderBrush="#E5E7EB" 
                                BorderThickness="1.5" 
                                CornerRadius="12" 
                                Padding="15" 
                                Margin="0,5"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconImage x:Name="icon" 
                                              Icon="MoneyBillWave" 
                                              Foreground="#9CA3AF" 
                                              Width="24" 
                                              Height="24"
                                              Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <ContentPresenter />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4F46E5"/>
                                <Setter TargetName="border" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Content -->
                <RowDefinition Height="70"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="15,15,0,0" Background="#002966">
                <Grid Margin="20,0">
                    <TextBlock Text="Procesar Pago" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>

                    <Button Command="{Binding CancelCommand}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <fa:IconImage Icon="Times" Foreground="White" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/> <!-- Left Column: Summary and Selector -->
                    <ColumnDefinition Width="20"/>  <!-- Divider -->
                    <ColumnDefinition Width="*"/>    <!-- Right Column: Contextual Panel -->
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Resumen de la Venta" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,10"/>
                        
                        <Border Background="#F9FAFB" CornerRadius="12" Padding="15" BorderBrush="#F3F4F6" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,3">
                                    <TextBlock Text="Cliente:" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding SelectedClient.FullName, FallbackValue='Consumidor Final'}" FontWeight="SemiBold" Foreground="#1F2937" HorizontalAlignment="Right"/>
                                </Grid>
                                <Separator Background="#F3F4F6" Margin="0,10"/>
                                <TextBlock Text="TOTAL A COBRAR" FontSize="10" FontWeight="Bold" Foreground="#6B7280"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding TotalAmount, StringFormat=N2}" FontSize="28" FontWeight="ExtraBold" Foreground="#002966"/>
                                    <TextBlock Text="{Binding SelectedCurrency}" FontSize="18" FontWeight="Bold" Foreground="#4F46E5" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Moneda de Pago" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,15,0,5"/>
                        <Border Background="#F9FAFB" CornerRadius="12" Padding="2" BorderBrush="#F3F4F6" BorderThickness="1" Margin="0,0,0,10">
                            <ComboBox ItemsSource="{Binding Currencies}" 
                                      SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                                      Height="35"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="#002966"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      VerticalContentAlignment="Center"
                                      Padding="10,0"/>
                        </Border>

                        <TextBlock Text="Método de Pago" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,10,0,10"/>
                        
                        <RadioButton IsChecked="{Binding IsCashPayment, Mode=TwoWay}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="border" 
                                            Background="White" 
                                            BorderBrush="#E5E7EB" 
                                            BorderThickness="1.5" 
                                            CornerRadius="12" 
                                            Padding="15" 
                                            Margin="0,5"
                                            Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <fa:IconImage x:Name="icon" 
                                                          Icon="MoneyBillWave" 
                                                          Foreground="#9CA3AF" 
                                                          Width="24" 
                                                          Height="24"
                                                          Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Efectivo" FontWeight="Bold" Foreground="#1F2937"/>
                                                <TextBlock Text="Pago con moneda nacional" FontSize="11" Foreground="#6B7280"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="#4F46E5"/>
                                            <Setter TargetName="border" Property="Background" Value="#EEF2FF"/>
                                            <Setter TargetName="icon" Property="Foreground" Value="#4F46E5"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F9FAFB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>

                        <RadioButton IsChecked="{Binding IsDigitalPayment, Mode=TwoWay}">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="border" 
                                            Background="White" 
                                            BorderBrush="#E5E7EB" 
                                            BorderThickness="1.5" 
                                            CornerRadius="12" 
                                            Padding="15" 
                                            Margin="0,5"
                                            Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <fa:IconImage x:Name="icon" 
                                                          Icon="CreditCard" 
                                                          Foreground="#9CA3AF" 
                                                          Width="24" 
                                                          Height="24"
                                                          Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Pago Digital / QR" FontWeight="Bold" Foreground="#1F2937"/>
                                                <TextBlock Text="Stripe Terminal / QR Code" FontSize="11" Foreground="#6B7280"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="#4F46E5"/>
                                            <Setter TargetName="border" Property="Background" Value="#EEF2FF"/>
                                            <Setter TargetName="icon" Property="Foreground" Value="#4F46E5"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F9FAFB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>

                <!-- Vertical Separator -->
                <Separator Grid.Column="1" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,10" Foreground="#E5E7EB"/>

                <!-- Right Column Panel Container -->
                <Grid Grid.Column="2">
                    
                    <!-- CASH METHOD PANEL -->
                    <Grid Style="{StaticResource CashPanelStyle}">
                        <StackPanel VerticalAlignment="Center" Margin="10,0">
                            <TextBlock Text="Cobro en Efectivo" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Monto Entregado por el Cliente" FontSize="12" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1.5" CornerRadius="8" Background="#F9FAFB" Height="50" Margin="0,0,0,20">
                                <Grid>
                                    <TextBlock Text="{Binding CurrencySymbol}" FontSize="20" FontWeight="Bold" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                    <TextBox Text="{Binding CashReceived, UpdateSourceTrigger=PropertyChanged}" 
                                             x:Name="TxtCashReceived"
                                             helpers:TextBoxBehavior.Restriction="Numeric"
                                             FontSize="22" 
                                             FontWeight="Bold" 
                                             Foreground="#1F2937" 
                                             BorderThickness="0" 
                                             Background="Transparent" 
                                             VerticalAlignment="Center" 
                                             Margin="35,0,15,0"
                                             TextAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Border Background="#ECFDF5" CornerRadius="12" Padding="20" BorderBrush="#A7F3D0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CAMBIO A ENTREGAR" FontSize="11" FontWeight="Bold" Foreground="#047857"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding ChangeDue, StringFormat=N2}" FontSize="36" FontWeight="ExtraBold" Foreground="#059669"/>
                                        <TextBlock Text="{Binding SelectedCurrency}" FontSize="18" FontWeight="Bold" Foreground="#059669" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- DIGITAL / QR METHOD PANEL -->
                    <Grid Style="{StaticResource DigitalPanelStyle}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0">
                            <TextBlock Text="Cobro Digital Stripe / QR" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- QR Code Rendering -->
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="8" Background="White" Margin="0,0,0,15">
                                <Image Source="{Binding QrCodeUrl}" Width="160" Height="160" Stretch="Uniform"/>
                            </Border>

                            <!-- Payment status indicator -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                                <fa:IconImage Icon="CircleNotch" 
                                              Foreground="#4F46E5" 
                                              Width="16" 
                                              Height="16"
                                              Margin="0,0,8,0">
                                    <fa:IconImage.Style>
                                        <Style TargetType="fa:IconImage">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsProcessingPayment}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </fa:IconImage.Style>
                                    <!-- Rotating animation for spinner -->
                                    <fa:IconImage.RenderTransform>
                                        <RotateTransform Angle="0" CenterX="8" CenterY="8"/>
                                    </fa:IconImage.RenderTransform>
                                    <fa:IconImage.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:1.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </fa:IconImage.Triggers>
                                </fa:IconImage>
                                
                                <TextBlock Text="{Binding PaymentStatus}" 
                                           FontWeight="SemiBold" 
                                           FontSize="13"
                                           Foreground="#4B5563"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Simulator Button -->
                            <Button Command="{Binding SimulatePaymentCommand}"
                                    Content="Simular Pago Pasarela" 
                                    Width="180" Height="38" 
                                    Background="#EEF2FF" 
                                    Foreground="#4F46E5" 
                                    BorderBrush="#C7D2FE"
                                    BorderThickness="1"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Footer Action Buttons -->
            <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0,0,15,15" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <Button Command="{Binding CancelCommand}"
                            Content="Cancelar" 
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Center" 
                            Width="120" Height="40" 
                            Background="White" 
                            Foreground="#4B5563" 
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Command="{Binding ConfirmPaymentCommand}"
                            Content="Confirmar Cobro" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="150" Height="40" 
                            Background="#059669" 
                            Foreground="White" 
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
