<Window x:Class="InventorySystem.Views.SupplierFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="15" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Gray"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Form -->
                <RowDefinition Height="70"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="15,15,0,0" Background="#3F51B5">
                <Grid>
                    <TextBlock Text="{Binding Title}" 
                               Foreground="White" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>

                    <Button HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,15,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <fa:IconImage Icon="Times" Foreground="White" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Form Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,10">
                <StackPanel>
                    
                    <!-- Basic Info Section -->
                    <TextBlock Text="Basic Information" Foreground="#3F51B5" FontWeight="Bold" Margin="0,10,0,10"/>
                    
                    <TextBlock Text="Document Number" Foreground="#757575" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Supplier.DocumentNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" Foreground="#757575" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding Supplier.FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last Name" Foreground="#757575" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding Supplier.LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Company Name" Foreground="#757575" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding Supplier.CompanyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>

                    <Separator Margin="0,20,0,10" Background="#F0F0F0"/>

                    <!-- Contact Section -->
                    <TextBlock Text="Contact Details" Foreground="#3F51B5" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Email" Foreground="#757575" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding Supplier.Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>

                    <TextBlock Text="Phone" Foreground="#757575" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding Supplier.PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>

                    <TextBlock Text="Website" Foreground="#757575" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding Supplier.Website, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>

                    <TextBlock Text="Address" Foreground="#757575" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding Supplier.Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    
                    <TextBlock Text="Category" Foreground="#757575" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding Supplier.Category, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource textBox}" Padding="5" Height="35"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer Actions -->
            <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0,0,15,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,25,0">
                    <Button Content="Cancel" 
                            Width="110" Height="40" 
                            Margin="0,0,12,0"
                            Background="White"
                            Foreground="#4B5563"
                            BorderBrush="#D1D5DB"
                            BorderThickness="1"
                            Cursor="Hand"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Save Supplier" 
                            Width="130" Height="40"
                            Background="#3F51B5"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            Command="{Binding SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
